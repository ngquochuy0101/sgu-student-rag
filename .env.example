# =============================================================================
# RAG SYSTEM - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env
# =============================================================================

# -------------------------------------------------------------------------
# REQUIRED: Google Gemini API Key
# -------------------------------------------------------------------------
# Get your free API key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=YOUR_API_KEY_HERE


# -------------------------------------------------------------------------
# OPTIONAL: Model Configuration
# -------------------------------------------------------------------------
# Uncomment and modify these to override default settings

# LLM Settings
# LLM_MODEL=gemini-2.5-flash
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=1024

# Run tagging (used in log filenames)
# RAG_RUN_NAME=dev-local

# Text Processing
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# Retrieval
# RETRIEVAL_K=3

# Paths (relative to workspace unless absolute)
# RAG_PDF_DIR=File_PDFs
# RAG_VECTOR_STORE_DIR=vector_store
# RAG_OCR_DIR=OCR
# RAG_ARTIFACTS_DIR=artifacts

# Embeddings
# EMBEDDING_DEVICE=cpu
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2

# OCR
# OCR_LANGUAGES=vie+eng
# OCR_DPI=2
# OCR_PSM=3
# OCR_OEM=1
# OCR_MIN_TEXT_CHARS=60
# OCR_CACHE_ENABLED=true


# -------------------------------------------------------------------------
# OPTIONAL: Alternative LLM Providers
# -------------------------------------------------------------------------
# If using OpenAI instead of Gemini
# OPENAI_API_KEY=sk-your-openai-key-here

# If using HuggingFace private models
# HUGGINGFACE_TOKEN=hf_your-token-here


# -------------------------------------------------------------------------
# NOTES:
# -------------------------------------------------------------------------
# 1. Never commit .env file to Git (already in .gitignore)
# 2. Use strong API keys and rotate them regularly
# 3. For production, use secret management services (AWS Secrets, Azure Key Vault, etc.)
# 4. Environment variables take precedence over config.py settings
